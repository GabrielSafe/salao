generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Salao {
  id         String   @id @default(uuid())
  nome       String
  slug       String   @unique
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  usuarios      Usuario[]
  clientes      Cliente[]
  funcionarias  Funcionaria[]
  atendimentos  Atendimento[]
  filaEntradas  FilaEntrada[]
  servicoItens  ServicoItem[]
  cadeiras      Cadeira[]

  @@map("saloes")
}

enum Role {
  SUPERADMIN
  ADMIN
  RECEPCIONISTA
  FUNCIONARIA
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  role      Role     @default(FUNCIONARIA)
  ativo     Boolean  @default(true)
  salaoId   String?  @map("salao_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  salao               Salao?             @relation(fields: [salaoId], references: [id])
  funcionaria         Funcionaria?
  pushSubscriptions   PushSubscription[]
  atendimentosCriados Atendimento[]      @relation("AtendimentoCriador")

  @@map("usuarios")
}

model PushSubscription {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  endpoint  String   @unique
  p256dhKey String   @map("p256dh_key")
  authKey   String   @map("auth_key")
  createdAt DateTime @default(now()) @map("created_at")

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

enum Especialidade {
  CABELO
  MAQUIAGEM
  MAO
  PE
  SOBRANCELHA
}

enum StatusFuncionaria {
  OFFLINE
  ONLINE
  AUSENTE
  EM_ATENDIMENTO
}

model Funcionaria {
  id             String            @id @default(uuid())
  usuarioId      String            @unique @map("usuario_id")
  salaoId        String            @map("salao_id")
  especialidades Especialidade[]
  cnpj           String?
  multiTarefas   Boolean           @default(false) @map("multi_tarefas")
  status          StatusFuncionaria @default(OFFLINE)
  ausenteDesde    DateTime?         @map("ausente_desde")
  ultimoBatimento DateTime?         @map("ultimo_batimento")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  usuario      Usuario       @relation(fields: [usuarioId], references: [id])
  salao        Salao         @relation(fields: [salaoId], references: [id])
  atendimentos Atendimento[]
  filaEntradas FilaEntrada[]

  @@map("funcionarias")
}

model Cliente {
  id            String    @id @default(uuid())
  nome          String
  telefone      String?
  cpf           String?
  email         String?
  genero        String?
  nascimento    DateTime?
  redesSociais  String?   @map("redes_sociais")
  comoConheceu  String?   @map("como_conheceu")
  observacoes   String?
  salaoId       String    @map("salao_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  salao        Salao         @relation(fields: [salaoId], references: [id])
  atendimentos Atendimento[]

  @@unique([cpf, salaoId])
  @@map("clientes")
}

enum StatusAtendimento {
  AGUARDANDO
  PENDENTE_ACEITE
  EM_ATENDIMENTO
  FINALIZADO
  CANCELADO
}

model Atendimento {
  id            String            @id @default(uuid())
  clienteId     String            @map("cliente_id")
  funcionariaId String?           @map("funcionaria_id")
  salaoId       String            @map("salao_id")
  tipoServico      Especialidade     @map("tipo_servico")
  status           StatusAtendimento @default(AGUARDANDO)
  numeroComanda    Int               @map("numero_comanda")
  propostaParaId   String?           @map("proposta_para_id")
  finalizadoPorAdm Boolean           @default(false) @map("finalizado_por_adm")
  cadeiraId        String?           @map("cadeira_id")
  servicoNome      String?           @map("servico_nome")
  servicoPreco     Float?            @map("servico_preco")
  iniciadoEm       DateTime?         @map("iniciado_em")
  finalizadoEm     DateTime?         @map("finalizado_em")
  fechadaEm          DateTime?         @map("fechada_em")
  recepcionistaId    String?           @map("recepcionista_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  cliente       Cliente      @relation(fields: [clienteId], references: [id])
  funcionaria   Funcionaria? @relation(fields: [funcionariaId], references: [id])
  salao         Salao        @relation(fields: [salaoId], references: [id])
  cadeira       Cadeira?     @relation(fields: [cadeiraId], references: [id])
  recepcionista Usuario?     @relation("AtendimentoCriador", fields: [recepcionistaId], references: [id])

  @@map("atendimentos")
}

model FilaEntrada {
  id            String        @id @default(uuid())
  funcionariaId String        @map("funcionaria_id")
  salaoId       String        @map("salao_id")
  especialidade Especialidade
  entradaEm     DateTime      @default(now()) @map("entrada_em")

  funcionaria Funcionaria @relation(fields: [funcionariaId], references: [id])
  salao       Salao       @relation(fields: [salaoId], references: [id])

  @@unique([funcionariaId, especialidade])
  @@map("fila_entradas")
}

model Cadeira {
  id        String   @id @default(uuid())
  numero    Int
  nome      String?
  ativo     Boolean  @default(true)
  salaoId   String   @map("salao_id")
  createdAt DateTime @default(now()) @map("created_at")

  salao        Salao         @relation(fields: [salaoId], references: [id])
  atendimentos Atendimento[]

  @@unique([numero, salaoId])
  @@map("cadeiras")
}

model ServicoItem {
  id         String        @id @default(uuid())
  nome       String
  grupo      String
  categoria  Especialidade
  preco      Float
  ativo      Boolean       @default(true)
  salaoId    String        @map("salao_id")
  createdAt  DateTime      @default(now()) @map("created_at")

  salao Salao @relation(fields: [salaoId], references: [id])

  @@map("servico_itens")
}

model ContadorComanda {
  salaoId  String @id @map("salao_id")
  contador Int    @default(0)

  @@map("contadores_comanda")
}
